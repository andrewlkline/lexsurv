{
  "name": "lexsurv",
  "private": true,
  "version": "0.1.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --mac --arm64"
  },
  "build": {
    "appId": "com.lexsurv.app",
    "productName": "LexSurv",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.education"
    }
  },
  "dependencies": {
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^1.3.2",
    "autoprefixer": "^10.4.14",
    "concurrently": "^6.5.1",
    "electron": "^22.3.27",
    "electron-builder": "^23.6.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "vite": "^2.9.15",
    "wait-on": "^6.0.1"
  }
}
